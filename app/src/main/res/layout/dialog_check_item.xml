<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tình trạng nhận lại thiết bị:"
        android:textColor="@color/text_secondary_color"
        android:textSize="13sp"
        android:layout_marginBottom="8dp" />

    <!-- Chọn tình trạng -->
    <RadioGroup
        android:id="@+id/rgConditionIn"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp">

        <RadioButton
            android:id="@+id/rbGood"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Tốt"
            android:textColor="@color/text_primary_color"
            android:checked="true" />

        <RadioButton
            android:id="@+id/rbDamaged"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Hỏng"
            android:textColor="@color/text_primary_color" />

        <RadioButton
            android:id="@+id/rbLost"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Mất"
            android:textColor="@color/text_primary_color" />
    </RadioGroup>

    <!-- Phụ kiện trả lại -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Phụ kiện trả lại"
        style="@style/DarkTextInputLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAccessoriesIn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Đầy đủ"
            android:textColor="@color/text_primary_color" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Ghi chú hỏng/mất -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Mô tả hỏng/mất (nếu có)"
        style="@style/DarkTextInputLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etDamageNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/text_primary_color" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Phí phạt bồi thường -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Phí bồi thường (VNĐ)"
        style="@style/DarkTextInputLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etPenaltyAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:inputType="number"
            android:text="0"
            android:textColor="@color/text_primary_color" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
