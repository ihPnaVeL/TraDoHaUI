<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_color"
    android:orientation="vertical">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="@color/primary"
        android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar"
        app:navigationIcon="@drawable/ic_arrow_back"
        app:titleTextColor="@color/white" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Card 1: Thông tin chung -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardGeneralInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="1dp"
                app:strokeColor="@color/card_stroke_color"
                app:cardBackgroundColor="@color/surface_color">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tvTicketCode"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Mã phiếu: BR-20231012-001"
                            android:textColor="@color/primary_light"
                            android:textSize="16sp"
                            android:textStyle="bold" />

                        <!-- Badge trạng thái -->
                        <TextView
                            android:id="@+id/tvStatusBadge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingHorizontal="10dp"
                            android:paddingVertical="4dp"
                            android:background="@drawable/bg_chip_category"
                            android:text="Trạng thái"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <View
                        android:id="@+id/divider"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="10dp"
                        android:background="@color/divider_color" />

                    <!-- Người mượn/trả -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Người thực hiện: "
                            android:textColor="@color/text_secondary_color"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvStudentName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Nguyễn Văn An"
                            android:textColor="@color/text_primary_color"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Ngày tạo -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Thời gian tạo: "
                            android:textColor="@color/text_secondary_color"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvDateCreated"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="12/10/2023 08:30"
                            android:textColor="@color/text_primary_color"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Hạn trả hoặc Ngày trả thực tế -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp">

                        <TextView
                            android:id="@+id/tvDateTargetLabel"
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Hạn trả dự kiến: "
                            android:textColor="@color/text_secondary_color"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvDateTargetValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="15/10/2023"
                            android:textColor="@color/text_primary_color"
                            android:textSize="13sp"
                            android:textStyle="bold" />

                    </LinearLayout>

                    <!-- Cán bộ xử lý -->
                    <LinearLayout
                        android:id="@+id/layoutHandler"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="6dp"
                        android:visibility="gone">

                        <TextView
                            android:id="@+id/tvHandlerLabel"
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:text="Người duyệt: "
                            android:textColor="@color/text_secondary_color"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvHandlerValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Cán bộ quản lý"
                            android:textColor="@color/text_primary_color"
                            android:textSize="13sp" />

                    </LinearLayout>

                    <!-- Ghi chú lý do / ghi chú xử lý -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="4dp">

                        <TextView
                            android:id="@+id/tvNoteLabel"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Lý do mượn / Ghi chú:"
                            android:textColor="@color/text_secondary_color"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tvNoteValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Lý do chi tiết"
                            android:textColor="@color/text_primary_color"
                            android:textSize="13sp" />

                    </LinearLayout>

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <!-- Card 2: Danh sách thiết bị -->
            <TextView
                android:id="@+id/tvTitleDeviceList"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="8dp"
                android:text="Danh sách thiết bị chi tiết"
                android:textColor="@color/text_primary_color"
                android:textSize="14sp"
                android:textStyle="bold" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvTicketItems"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>
