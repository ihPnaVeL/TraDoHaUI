<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Chọn thiết bị vật lý khả dụng:"
        android:textColor="@color/text_secondary_color"
        android:textSize="13sp"
        android:layout_marginBottom="6dp" />

    <!-- Spinner chọn DeviceDetail -->
    <Spinner
        android:id="@+id/spinnerDeviceDetail"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:background="@drawable/bg_chip_category"
        android:paddingHorizontal="10dp"
        android:layout_marginBottom="16dp" />

    <!-- Tình trạng lúc giao -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:hint="Tình trạng bàn giao"
        style="@style/DarkTextInputLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etConditionOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tốt"
            android:textColor="@color/text_primary_color" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Phụ kiện lúc giao -->
    <com.google.android.material.textfield.TextInputLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Phụ kiện kèm theo"
        style="@style/DarkTextInputLayout">

        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAccessoriesOut"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Không"
            android:textColor="@color/text_primary_color" />
    </com.google.android.material.textfield.TextInputLayout>

</LinearLayout>
