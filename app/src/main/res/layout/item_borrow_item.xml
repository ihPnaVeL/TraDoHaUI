<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:strokeWidth="1dp"
    app:strokeColor="@color/card_stroke_color"
    app:cardBackgroundColor="@color/surface_color">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- Thông tin thiết bị -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/tvDeviceName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tên loại thiết bị"
                    android:textColor="@color/text_primary_color"
                    android:textSize="15sp"
                    android:textStyle="bold" />

                <!-- Note/Loại yêu cầu ban đầu -->
                <TextView
                    android:id="@+id/tvOriginalRequest"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Ghi chú: Yêu cầu Laptop"
                    android:textColor="@color/text_secondary_color"
                    android:textSize="12sp" />

            </LinearLayout>

            <!-- Nút Gán thiết bị (dành cho Admin) -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAssign"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Gán TB"
                android:textSize="12sp"
                android:textColor="@color/primary_light"
                android:visibility="gone" />

        </LinearLayout>

        <!-- Phần thông tin thiết bị vật lý cụ thể sau khi đã gán -->
        <LinearLayout
            android:id="@+id/layoutPhysicalDetails"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@color/divider_color"
            android:orientation="vertical"
            android:padding="8dp"
            android:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvAssetCode"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Mã TS: HAU-LAP-001"
                    android:textColor="@color/text_primary_color"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/tvSerialNumber"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Serial: DELL001"
                    android:textColor="@color/text_primary_color"
                    android:textSize="12sp" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/tvConditionOut"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tình trạng: Tốt"
                    android:textColor="@color/text_secondary_color"
                    android:textSize="12sp" />

                <TextView
                    android:id="@+id/tvAccessoriesOut"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Phụ kiện: Sạc, túi"
                    android:textColor="@color/text_secondary_color"
                    android:textSize="12sp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Trạng thái Chưa gán (hiển thị khi device_detail_id == 0) -->
        <TextView
            android:id="@+id/tvUnassignedWarning"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="⚠️ Chưa gán thiết bị vật lý"
            android:textColor="@color/status_pending"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
