<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#121212">

    <!-- Main Content Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- ── HEADER ── -->
        <LinearLayout
            android:id="@+id/layoutHeader"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_student_header"
            android:orientation="vertical"
            android:paddingHorizontal="20dp"
            android:paddingTop="36dp"
            android:paddingBottom="36dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Hamburger menu button -->
                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnMenu"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_header_btn"
                    android:src="@drawable/ic_menu"
                    android:tint="@color/white"
                    android:contentDescription="Menu" />

                <!-- Centralized Title Layout -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BẢNG ĐIỀU KHIỂN"
                        android:textColor="#CCFFFFFF"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.05" />
                    <TextView
                        android:id="@+id/tvAdminDashboardTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Quản trị viên"
                        android:textColor="@color/white"
                        android:textSize="19sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Notification Bell -->
                <androidx.appcompat.widget.AppCompatImageButton
                    android:id="@+id/btnNotification"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:background="@drawable/bg_header_btn"
                    android:src="@drawable/ic_bell"
                    android:tint="@color/white"
                    android:contentDescription="Thông báo" />

            </LinearLayout>

            <!-- Admin welcome info sub-bar (hidden to match design but preserved for code references) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tvAdminName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Admin" />
            </LinearLayout>

        </LinearLayout>

        <!-- Scrollable Content -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="24dp">

                <!-- 3 Stats Cards in a single row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:orientation="horizontal">

                    <!-- Pending Borrow Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPendingBorrowStat"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="#231709"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E67E22">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:id="@+id/tvPendingBorrow"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#E67E22"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chờ duyệt\nmượn"
                                android:textColor="#E67E22"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:gravity="center" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Pending Return Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardPendingReturnStat"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="6dp"
                        app:cardBackgroundColor="#0A1F14"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#27AE60">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:id="@+id/tvPendingReturn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#27AE60"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Chờ xác\nnhận trả"
                                android:textColor="#27AE60"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:gravity="center" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <!-- Overdue Card -->
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardOverdueStat"
                        android:layout_width="0dp"
                        android:layout_height="110dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardBackgroundColor="#2A0B0D"
                        app:cardCornerRadius="16dp"
                        app:cardElevation="0dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#E74C3C">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="8dp">

                            <TextView
                                android:id="@+id/tvOverdue"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:textColor="#E74C3C"
                                android:textSize="32sp"
                                android:textStyle="bold" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Quá hạn"
                                android:textColor="#E74C3C"
                                android:textSize="11sp"
                                android:textStyle="bold"
                                android:gravity="center" />

                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Hidden/legacy text views to prevent crashes if code queries them -->
                <TextView
                    android:id="@+id/tvDeviceBorrowed"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />
                <TextView
                    android:id="@+id/tvDeviceDamaged"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:visibility="gone" />

                <!-- Section Label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Quản lý phiếu"
                    android:textColor="#E0E0E0"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <!-- Duyệt phiếu mượn Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnBorrowApproval"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="14dp"
                    android:text="DUYỆT PHIẾU MƯỢN"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="#1962D1"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_checkbox_circle"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconTint="@color/white" />

                <!-- Xác nhận phiếu trả Button -->
                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnReturnApproval"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:layout_marginBottom="24dp"
                    android:text="XÁC NHẬN PHIẾU TRẢ"
                    android:textColor="@color/white"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    app:backgroundTint="#27AE60"
                    app:cornerRadius="14dp"
                    app:icon="@drawable/ic_return"
                    app:iconGravity="textStart"
                    app:iconPadding="12dp"
                    app:iconTint="@color/white" />

                <!-- Management Cards for legacy compatibility and direct access -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    android:text="Quản lý hệ thống"
                    android:textColor="#E0E0E0"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:visibility="gone" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="16dp"
                    android:visibility="gone">

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardDeviceManage"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        app:cardBackgroundColor="#1C1C1E"
                        app:cardCornerRadius="14dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#2C2C2E">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_device"
                                android:tint="@color/white" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Thiết bị"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardUserManage"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginHorizontal="6dp"
                        app:cardBackgroundColor="#1C1C1E"
                        app:cardCornerRadius="14dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#2C2C2E">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_profile"
                                android:tint="@color/white" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Sinh viên"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/cardReport"
                        android:layout_width="0dp"
                        android:layout_height="80dp"
                        android:layout_weight="1"
                        android:layout_marginStart="6dp"
                        app:cardBackgroundColor="#1C1C1E"
                        app:cardCornerRadius="14dp"
                        app:strokeWidth="1dp"
                        app:strokeColor="#2C2C2E">
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:gravity="center"
                            android:orientation="vertical">
                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_report"
                                android:tint="@color/white" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="4dp"
                                android:text="Báo cáo"
                                android:textColor="@color/white"
                                android:textSize="12sp"
                                android:textStyle="bold" />
                        </LinearLayout>
                    </com.google.android.material.card.MaterialCardView>

                </LinearLayout>

                <!-- Warning Overdue Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/cardOverdueWarning"
                    android:layout_width="match_parent"
                    android:layout_height="72dp"
                    android:layout_marginBottom="24dp"
                    app:cardBackgroundColor="#1C1C1E"
                    app:cardCornerRadius="14dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#2C2C2E">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingHorizontal="16dp">
                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:background="@drawable/bg_warning_circle"
                            android:src="@drawable/ic_warning"
                            android:tint="#E67E22"
                            android:padding="8dp" />
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Danh sách quá hạn"
                                android:textColor="@color/white"
                                android:textSize="14sp"
                                android:textStyle="bold" />
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Xem phiếu đã quá hạn trả"
                                android:textColor="#B0B0B0"
                                android:textSize="12sp" />
                        </LinearLayout>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textColor="#8E8E8E"
                            android:textSize="24sp" />
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>
        </ScrollView>

    </LinearLayout>

    <!-- Side Navigation Menu Drawer -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        android:background="#1C1C1E"
        app:itemIconTint="#FFFFFF"
        app:itemTextColor="#FFFFFF"
        app:headerLayout="@layout/nav_header_admin"
        app:menu="@menu/menu_admin_drawer" />

</androidx.drawerlayout.widget.DrawerLayout>
